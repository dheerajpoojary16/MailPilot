@model BulkMailSender.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MailPilot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2563eb;
            --primary-hover: #1d4ed8;
            --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
            --card-bg: rgba(255, 255, 255, 0.85);
            --card-border: rgba(255, 255, 255, 0.7);
            --text-main: #0f172a;
            --text-muted: #64748b;
        }

        body {
            background: var(--bg-gradient);
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
            position: relative;
        }

        /* Ambient Glow Blobs */
        .blob {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            filter: blur(120px);
            opacity: 0.15;
            z-index: 1;
            animation: drift 20s infinite alternate ease-in-out;
        }
        .blob-1 {
            background: #2563eb;
            top: -150px;
            left: -150px;
        }
        .blob-2 {
            background: #a855f7;
            bottom: -150px;
            right: -150px;
            animation-delay: -7s;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
            position: relative;
            z-index: 10;
        }

        /* Upgraded Glassmorphism Card */
        .login-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 28px;
            padding: 45px 40px;
            box-shadow: 
                0 4px 6px -1px rgba(0, 0, 0, 0.01),
                0 20px 40px -10px rgba(37, 99, 235, 0.06),
                0 40px 80px -15px rgba(0, 0, 0, 0.04),
                inset 0 1px 1px rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .brand-logo-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 35px;
        }

        .brand-icon {
            font-size: 3.8rem;
            background: linear-gradient(135deg, var(--primary-color), #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 8px 16px rgba(37, 99, 235, 0.15));
            animation: float 5s ease-in-out infinite;
        }

        .brand-title {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-color) 0%, #6366f1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.04em;
            margin-top: 8px;
        }

        .brand-subtitle {
            color: var(--text-muted);
            font-size: 0.88rem;
            font-weight: 400;
            margin-top: 2px;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-main);
            margin-bottom: 8px;
            display: block;
        }

        /* Seamless Input Group */
        .premium-input-group {
            border-radius: 14px;
            border: 1px solid #cbd5e1;
            background: #ffffff;
            transition: all 0.2s ease;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .premium-input-group:focus-within {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.08);
        }

        .premium-input-group .input-group-text {
            border: none !important;
            background: transparent !important;
            padding-left: 16px;
            padding-right: 4px;
            color: #94a3b8 !important;
            font-size: 1.1rem;
            transition: color 0.2s ease;
        }

        .premium-input-group:focus-within .input-group-text {
            color: var(--primary-color) !important;
        }

        .premium-input-group .premium-input {
            border: none !important;
            background: transparent !important;
            box-shadow: none !important;
            padding: 14px 16px 14px 8px !important;
            font-size: 0.95rem !important;
            color: var(--text-main) !important;
            flex-grow: 1;
        }

        .premium-input::placeholder {
            color: #94a3b8;
        }

        /* Interactive Buttons */
        .btn-admin-login {
            background: linear-gradient(135deg, var(--primary-color), var(--primary-hover));
            border: none;
            border-radius: 14px;
            padding: 14px 24px;
            color: white;
            font-weight: 600;
            font-size: 0.98rem;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.15);
        }

        .btn-admin-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(37, 99, 235, 0.25);
        }

        .btn-admin-login:active {
            transform: translateY(0);
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: var(--text-muted);
            margin: 30px 0;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 500;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        }

        .divider:not(:empty)::before {
            margin-right: 1em;
        }

        .divider:not(:empty)::after {
            margin-left: 1em;
        }

        .btn-guest-explore {
            background: rgba(255, 255, 255, 0.85);
            border: 1px dashed rgba(37, 99, 235, 0.3);
            border-radius: 14px;
            padding: 15px 24px;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.01);
        }

        .btn-guest-explore:hover {
            background: rgba(37, 99, 235, 0.04);
            border-color: var(--primary-color);
            border-style: solid;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.05);
        }

        .btn-guest-explore:active {
            transform: translateY(0);
        }

        .alert-premium {
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.15);
            color: #ef4444;
            border-radius: 14px;
            font-size: 0.85rem;
            padding: 14px;
            margin-bottom: 25px;
        }

        .features-grid {
            display: flex;
            justify-content: space-around;
            margin-top: 35px;
            font-size: 0.78rem;
            color: var(--text-muted);
            text-align: center;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
            padding-top: 25px;
        }

        .feature-item i {
            font-size: 1.2rem;
            color: var(--primary-color);
            margin-bottom: 6px;
            display: block;
        }

        @@keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-8px) rotate(1deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }

        @@keyframes drift {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(40px, 20px) scale(1.08); }
            100% { transform: translate(-20px, -40px) scale(0.92); }
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <!-- Decorative Glowing Blobs -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <div class="login-container">
        <div class="login-card">
            
            <div class="brand-logo-container">
                <i class="bi bi-send-fill brand-icon"></i>
                <h1 class="brand-title">MailPilot</h1>
                <p class="brand-subtitle">Bulk Mail Management System</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-premium d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill text-danger fs-5"></i>
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-medium"></div>
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <div class="premium-input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="premium-input" placeholder="admin@mailpilot.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="premium-input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" class="premium-input" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" name="submitType" value="admin" class="btn btn-admin-login w-100 d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-shield-lock-fill"></i> Login
                </button>
                
                <div class="divider">Or explore safely</div>

                <button type="submit" name="submitType" value="guest" class="btn btn-guest-explore">
                    <i class="bi bi-lightning-charge-fill text-warning"></i> Explore as Guest (1-Click Demo)
                </button>
            </form>

            <div class="features-grid">
                <div class="feature-item">
                    <i class="bi bi-envelope-check"></i>
                    <span>Bulk Send</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Templates</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-eye"></i>
                    <span>Live Preview</span>
                </div>
            </div>

        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
