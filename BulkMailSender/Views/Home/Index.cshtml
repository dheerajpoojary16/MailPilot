@model BulkMailSender.ViewModels.EmailViewModel

<div class="row g-4 fade-in">
    <!-- Left Column: Main Form -->
    <div class="col-lg-7">
        <div class="main-card premium-card">
            <h2 class="page-title mb-1">MailPilot</h2>
            <p class="text-muted mb-4">Compose and send emails to your audience efficiently.</p>

            @if (User.IsInRole("Guest"))
            {
                <div class="alert border-0 shadow-sm d-flex align-items-center mb-4 rounded-4 py-3" style="background: rgba(13, 202, 240, 0.08); backdrop-filter: blur(5px); border-left: 4px solid #0dcaf0 !important;">
                    <i class="bi bi-lightning-charge-fill me-3 fs-4 text-info"></i>
                    <div>
                        <strong class="text-info-emphasis" style="font-size: 0.95rem; color: #0891b2 !important;">Demo Mode Active</strong>
                        <div class="text-muted small mt-1" style="font-size: 0.8rem;">You are exploring MailPilot as a guest. All email dispatches will be simulated safely with zero actual emails sent.</div>
                    </div>
                </div>
            }

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success d-flex align-items-center mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <div>@ViewBag.Message</div>
                </div>
            }

            <form id="emailForm" asp-controller="Home" asp-action="Send" method="post" enctype="multipart/form-data">
                
                <!-- TEMPLATE -->
                <div class="mb-4">
                    <label class="form-label">Select Template</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-file-earmark-text"></i></span>
                        <select asp-for="SelectedTemplateId" id="templateDropdown" class="form-control border-start-0 ps-0">
                            <option value="">-- Select Template --</option>
                            @foreach (var item in Model.Templates)
                            {
                                <option value="@item.Id">@item.TemplateName</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- EMAILS -->
                <div class="mb-4">
                    <label class="form-label d-flex justify-content-between">
                        <span>Emails</span>
                        <small class="text-muted" id="emailCountDisplay">0 recipients</small>
                    </label>
                    <textarea asp-for="Emails" id="emailsBox" class="form-control premium-textarea" rows="4" placeholder="Enter emails separated by commas"></textarea>
                </div>

                <!-- SUBJECT -->
                <div class="mb-4">
                    <label class="form-label">Subject</label>
                    <input asp-for="Subject" id="subjectBox" class="form-control premium-input" placeholder="Enter email subject" />
                </div>

                <!-- BODY -->
                <div class="mb-4">
                    <label class="form-label">Body</label>
                    <textarea asp-for="Body" id="bodyBox" class="form-control premium-textarea" rows="10" placeholder="Write your email body here..."></textarea>
                </div>

                <!-- ATTACHMENT -->
                <div class="mb-4">
                    <label class="form-label">Attachment</label>
                    <input asp-for="Attachment" id="attachmentBox" type="file" class="form-control premium-input" />
                </div>

                <!-- TEMPLATE FILE NAME -->
                <div class="template-info d-flex align-items-center gap-2 mb-4" id="attachmentName" style="display:none !important;">
                    <i class="bi bi-paperclip"></i>
                    <span id="attachmentNameText"></span>
                </div>

                <!-- HIDDEN ATTACHMENT -->
                <input type="hidden" id="hiddenAttachment" name="TemplateAttachment" />

                <!-- BUTTON -->
                <div class="d-flex justify-content-end mt-2">
                    <button type="submit" class="send-btn d-flex align-items-center gap-2">
                        <i class="bi bi-send-fill"></i> Send Emails
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Right Column: Live Preview -->
    <div class="col-lg-5">
        <div class="preview-panel sticky-top" style="top: 24px;">
            <div class="preview-header d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                <h6 class="m-0 fw-bold d-flex align-items-center gap-2"><i class="bi bi-eye"></i> Live Preview</h6>
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Live</span>
            </div>
            
            <div class="preview-content">
                <div class="preview-field mb-3 border-bottom pb-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">To</small>
                    <div class="mt-1 fs-6 text-dark" id="previewRecipients">No recipients added</div>
                </div>

                <div class="preview-field mb-3 border-bottom pb-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Subject</small>
                    <div class="mt-1 fs-5 fw-bold text-dark" id="previewSubject">New Email</div>
                </div>

                <div class="preview-field mb-3">
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Message</small>
                    <div class="mt-2 preview-body-box bg-light rounded p-3 text-dark" style="min-height: 200px; white-space: pre-wrap;" id="previewBody">Your email body will appear here...</div>
                </div>

                <div class="preview-attachment-box mt-3 p-3 rounded bg-light border d-none align-items-center gap-2" id="previewAttachmentContainer">
                    <i class="bi bi-file-earmark-pdf-fill text-danger fs-4"></i>
                    <span id="previewAttachmentText" class="fw-medium text-truncate"></span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Live Preview Logic
    const emailsBox = document.getElementById("emailsBox");
    const subjectBox = document.getElementById("subjectBox");
    const bodyBox = document.getElementById("bodyBox");
    const attachmentBox = document.getElementById("attachmentBox");

    const emailCountDisplay = document.getElementById("emailCountDisplay");
    const previewRecipients = document.getElementById("previewRecipients");
    const previewSubject = document.getElementById("previewSubject");
    const previewBody = document.getElementById("previewBody");
    const previewAttachmentContainer = document.getElementById("previewAttachmentContainer");
    const previewAttachmentText = document.getElementById("previewAttachmentText");

    function updatePreview() {
        // Update Emails
        const emails = emailsBox.value.split(',').map(e => e.trim()).filter(e => e.length > 0);
        const count = emails.length;
        emailCountDisplay.innerText = count === 1 ? '1 recipient' : `${count} recipients`;
        
        if (count > 0) {
            previewRecipients.innerHTML = `<span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">${count} recipient(s)</span>`;
        } else {
            previewRecipients.innerHTML = 'No recipients added';
        }

        // Update Subject
        previewSubject.innerText = subjectBox.value || 'New Email';

        // Update Body
        previewBody.innerText = bodyBox.value || 'Your email body will appear here...';
    }

    emailsBox.addEventListener("input", updatePreview);
    subjectBox.addEventListener("input", updatePreview);
    bodyBox.addEventListener("input", updatePreview);

    // Attachment Box Change
    attachmentBox.addEventListener("change", function() {
        if (this.files && this.files.length > 0) {
            previewAttachmentContainer.classList.remove("d-none");
            previewAttachmentContainer.classList.add("d-flex");
            previewAttachmentText.innerText = this.files[0].name;
        } else {
            previewAttachmentContainer.classList.add("d-none");
            previewAttachmentContainer.classList.remove("d-flex");
        }
    });

    // Template Logic
    document.getElementById("templateDropdown").addEventListener("change", function () {
        let templateId = this.value;
        
        if (!templateId) return;

        fetch('/Home/GetTemplate?id=' + templateId)
            .then(response => response.json())
            .then(data => {
                subjectBox.value = data.sub;
                bodyBox.value = data.body;
                document.getElementById("hiddenAttachment").value = data.attachment;
                
                const attachmentNameEl = document.getElementById("attachmentName");
                const attachmentNameText = document.getElementById("attachmentNameText");
                
                if (data.attachment) {
                    attachmentNameEl.style.setProperty("display", "flex", "important");
                    const fileName = data.attachment.split('/').pop();
                    attachmentNameText.innerText = "Template Attachment: " + fileName;
                    
                    previewAttachmentContainer.classList.remove("d-none");
                    previewAttachmentContainer.classList.add("d-flex");
                    previewAttachmentText.innerText = fileName;
                } else {
                    attachmentNameEl.style.setProperty("display", "none", "important");
                }
                
                // Trigger preview update
                updatePreview();
            });
    });

    // Initial update on load
    updatePreview();

    // AJAX Form Submission
    document.getElementById("emailForm").addEventListener("submit", function(e) {
        e.preventDefault();
        
        const btn = document.querySelector(".send-btn");
        const originalContent = btn.innerHTML;
        
        // Show spinner
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Sending...';
        btn.disabled = true;

        const formData = new FormData(this);

        fetch(this.action, {
            method: this.method,
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            btn.innerHTML = originalContent;
            btn.disabled = false;

            if (data.success) {
                if (data.isDemo) {
                    Swal.fire({
                        icon: 'info',
                        title: 'Demo Mail Simulated!',
                        text: data.message,
                        confirmButtonColor: '#2563eb'
                    });
                } else {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: data.message,
                        confirmButtonColor: '#2563eb',
                        timer: 3000,
                        timerProgressBar: true
                    });
                }
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Failed to Send',
                    text: data.message || 'An unknown error occurred.',
                    confirmButtonColor: '#2563eb'
                });
            }
        })
        .catch(error => {
            btn.innerHTML = originalContent;
            btn.disabled = false;
            Swal.fire({
                icon: 'error',
                title: 'Network Error',
                text: 'Something went wrong communicating with the server.',
                confirmButtonColor: '#2563eb'
            });
        });
    });
</script>